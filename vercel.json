{
  "rewrites": [
    { "source": "/blog", "destination": "/api/blog" },
    { "source": "/blog/", "destination": "/api/blog" },
    { "source": "/blog/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/blog/:slug", "destination": "/api/post?slug=:slug" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
